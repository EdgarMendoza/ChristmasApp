@inherits LayoutComponentBase

<MudThemeProvider Theme="_currentTheme" />
<MudPopoverProvider />
<MudDialogProvider />
<MudSnackbarProvider />

<MudLayout>
    <MudAppBar Color="Color.Inherit" Fixed="true" Elevation="0" Class="glass-panel" Style="border-bottom: 1px solid rgba(0,0,0,0.05);">
        <MudIconButton Icon="@Icons.Material.Filled.Menu" Color="Color.Primary" Edge="Edge.Start" OnClick="@((e) => ToggleDrawer())" />
        <MudText Typo="Typo.h6" Color="Color.Primary" Class="font-weight-bold ml-2">Holiday Helper</MudText>
        <MudSpacer />
        <MudButton Variant="Variant.Text" Color="Color.Secondary" Href="/secretsanta" StartIcon="@Icons.Material.Filled.CardGiftcard" Class="hidden-sm-and-down">Secret Santa</MudButton>
    </MudAppBar>
    <MudDrawer @bind-Open="@_drawerOpen" Elevation="1">
        <MudDrawerHeader>
            <MudText Typo="Typo.h6">Menu</MudText>
        </MudDrawerHeader>
        <MudNavMenu>
            <MudNavLink Href="/" Icon="@Icons.Material.Filled.Home" Match="NavLinkMatch.All">Home</MudNavLink>
            <MudNavLink Href="/secretsanta" Icon="@Icons.Material.Filled.CardGiftcard" Match="NavLinkMatch.Prefix">Secret Santa</MudNavLink>
        </MudNavMenu>
    </MudDrawer>
    <MudMainContent Style="background-color: #f7f9f9; min-height: 100vh;">
        <MudContainer MaxWidth="MaxWidth.Medium" Class="pt-6 pb-8">
            @Body
        </MudContainer>
    </MudMainContent>
</MudLayout>

@code {
    private MudTheme _currentTheme = new MudTheme()
    {
        PaletteLight = new PaletteLight()
        {
            Primary = "#C62828", // Richer Christmas Red
            Secondary = "#1B5E20", // Richer Christmas Green
            Tertiary = "#FBC02D", // Gold
            AppbarBackground = "#FFFFFF", // Clean white appbar
            AppbarText = "#212121",
            Background = "#F5F7FA", // Off-white/slate snow background
            Surface = "#FFFFFF",
            TextPrimary = "#1E293B", // Softer, premium dark text
            TextSecondary = "#64748B",
            ActionDefault = "#1B5E20",
            PrimaryDarken = "#B71C1C",
            SecondaryDarken = "#144818"
        },
        LayoutProperties = new LayoutProperties()
        {
            DefaultBorderRadius = "20px" // Softer, modern corners
        }
    };

    private bool _drawerOpen = false;

    private void ToggleDrawer() => _drawerOpen = !_drawerOpen;
}
