@using ChristmasApp.SecretSanta

@if (IsFinished)
{
    <MudPaper Class="pa-8 text-center glass-panel rounded-xl reveal-animation" Elevation="0" Style="position: relative;">
        <MudIconButton Icon="@Icons.Material.Filled.Edit" Color="Color.Default" OnClick="Edit" Size="Size.Small" Style="position: absolute; top: 16px; right: 16px;" />
        
        <MudIcon Icon="@Icons.Material.Filled.CheckCircle" Color="Color.Success" Style="font-size: 5rem;" Class="mb-4 mx-auto" />
        <MudText Typo="Typo.h3" Class="mb-4 font-weight-bold" Align="Align.Center" Color="Color.Primary">All Done!</MudText>
        <MudText Typo="Typo.h6" Class="mb-8 text-muted" Align="Align.Center">Everyone has seen their Secret Santa assignment. Enjoy the gift exchange!</MudText>
        
        <div class="d-flex flex-column gap-4 align-center" style="max-width: 400px; margin: 0 auto;">
            <MudButton Variant="Variant.Filled" Color="Color.Primary" Size="Size.Large" OnClick="FinishAndClear" FullWidth="true" Class="hover-lift py-3 rounded-lg font-weight-bold">
                Finish & Clear All
            </MudButton>
            <MudButton Variant="Variant.Text" Color="Color.Secondary" Size="Size.Large" OnClick="Edit" FullWidth="true" Class="font-weight-bold">
                Edit Participants
            </MudButton>
        </div>
    </MudPaper>
}
else if (CurrentParticipant != null)
{
    <MudPaper Class="pa-6 pa-md-10 text-center glass-panel rounded-xl" Elevation="0" Style="min-height: 500px; display: flex; flex-direction: column; justify-content: center; position: relative; overflow: hidden;">
        <MudIconButton Icon="@Icons.Material.Filled.Edit" Color="Color.Default" OnClick="Edit" Size="Size.Small" Style="position: absolute; top: 16px; right: 16px; z-index: 10;" />

        @if (!ShowAssignment && !_isRevealing)
        {
            <div class="d-flex flex-column align-center reveal-animation">
                <div class="pa-6 rounded-circle mb-6" style="background-color: rgba(198, 40, 40, 0.05);">
                    <MudIcon Icon="@Icons.Material.Filled.Smartphone" Color="Color.Primary" Style="font-size: 6rem;" />
                </div>
                <MudText Typo="Typo.h4" Class="mb-8" Align="Align.Center">Pass the phone to <br/> <b style="color: var(--mud-palette-primary); font-size: 1.2em;">@CurrentParticipant.Name</b></MudText>
                <MudButton Variant="Variant.Filled" Color="Color.Secondary" Size="Size.Large" OnClick="Reveal" Class="hover-lift py-3 px-8 rounded-lg font-weight-bold" Style="font-size: 1.1rem;">
                    I am @CurrentParticipant.Name
                </MudButton>
            </div>
        }
        else if (_isRevealing)
        {
            <div class="pulse-container d-flex flex-column align-center justify-center">
                <MudIcon Icon="@Icons.Material.Filled.CardGiftcard" Color="Color.Tertiary" Style="font-size: 7rem; filter: drop-shadow(0px 10px 20px rgba(251, 192, 45, 0.4));" Class="mb-6 pulsing-icon" />
                <MudText Typo="Typo.h5" Align="Align.Center" Class="font-weight-bold text-muted">Opening your assignment...</MudText>
            </div>
        }
        else
        {
            <div class="reveal-animation d-flex flex-column align-center" style="width: 100%;">
                <MudIcon Icon="@Icons.Material.Filled.CheckCircleOutline" Color="Color.Success" Style="font-size: 4rem;" Class="mb-4" />
                <MudText Typo="Typo.h6" Class="mb-2 text-muted" Align="Align.Center">You are giving a gift to:</MudText>
                
                <div class="pa-6 rounded-xl mb-6 w-100" style="background: linear-gradient(135deg, rgba(198,40,40,0.05) 0%, rgba(27,94,32,0.05) 100%); border: 2px dashed rgba(198,40,40,0.2);">
                    <MudText Typo="Typo.h2" Color="Color.Primary" Class="font-weight-bold" Align="Align.Center" Style="letter-spacing: -1px;">
                        @AssignedParticipant?.Name
                    </MudText>
                </div>
                
                @if (!string.IsNullOrWhiteSpace(AssignedParticipant?.GiftNotes))
                {
                    <MudAlert Severity="Severity.Info" Class="mb-8 text-center rounded-lg shadow-sm" ContentAlignment="HorizontalAlignment.Center" Style="width: 100%;">
                        <b>Wishlist / Notes:</b><br />
                        <span style="font-size: 1.1rem;">@AssignedParticipant.GiftNotes</span>
                    </MudAlert>
                }

                <MudText Typo="Typo.body1" Color="Color.Error" Class="mb-8" Align="Align.Center">
                    <MudIcon Icon="@Icons.Material.Filled.Warning" Size="Size.Small" Class="mr-1 mb-1"/>
                    <b>Memorize this!</b> Do not tell anyone else.
                </MudText>
                
                <MudButton Variant="Variant.Filled" Color="Color.Dark" Size="Size.Large" OnClick="NextPerson" Class="hover-lift py-3 px-8 rounded-lg font-weight-bold w-100" Style="max-width: 300px;">
                    Hide & Next Person
                </MudButton>
            </div>
        }
    </MudPaper>
}

@code {
    [Parameter]
    public List<Participant> Participants { get; set; } = new();

    [Parameter]
    public List<Assignment> Assignments { get; set; } = new();

    [Parameter]
    public EventCallback OnEdit { get; set; }

    [Parameter]
    public EventCallback OnFinishAndClear { get; set; }

    private int CurrentIndex { get; set; } = 0;
    private bool ShowAssignment { get; set; } = false;
    private bool _isRevealing = false;
    private bool IsFinished => CurrentIndex >= Participants.Count;

    private Participant? CurrentParticipant => IsFinished ? null : Participants[CurrentIndex];
    
    private Participant? AssignedParticipant
    {
        get
        {
            if (CurrentParticipant == null) return null;
            var assignment = Assignments.FirstOrDefault(a => a.GiverId == CurrentParticipant.Id);
            if (assignment == null) return null;
            return Participants.FirstOrDefault(p => p.Id == assignment.ReceiverId);
        }
    }

    private async Task Reveal()
    {
        _isRevealing = true;
        StateHasChanged();
        
        await Task.Delay(1500);
        
        _isRevealing = false;
        ShowAssignment = true;
        StateHasChanged();
    }

    private void NextPerson()
    {
        ShowAssignment = false;
        CurrentIndex++;
    }

    private async Task Edit()
    {
        await OnEdit.InvokeAsync();
    }

    private async Task FinishAndClear()
    {
        await OnFinishAndClear.InvokeAsync();
    }
}
