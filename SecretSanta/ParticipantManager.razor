@using ChristmasApp.SecretSanta
@inject ISnackbar Snackbar

<MudPaper Class="pa-6 mb-8 glass-panel rounded-xl" Elevation="0">
    <MudText Typo="Typo.h5" Class="mb-6 font-weight-bold" Color="Color.Primary">Add Participant</MudText>
    <MudForm @ref="_form" Class="d-flex flex-column gap-5">
        <MudTextField @bind-Value="_newName" Label="Name" Required="true" RequiredError="Name is required!" FullWidth="true" Variant="Variant.Outlined" />
        <MudTextField @bind-Value="_newNotes" Label="Gift Notes / Wishlist (Optional)" FullWidth="true" Variant="Variant.Outlined" Lines="2" />
        <MudButton Variant="Variant.Filled" Color="Color.Primary" Size="Size.Large" OnClick="AddParticipant" FullWidth="true" Class="mt-2 py-3 rounded-lg hover-lift font-weight-bold">
            Add Participant
        </MudButton>
    </MudForm>
</MudPaper>

@if (Participants.Any())
{
    <MudTable Items="@Participants" Hover="true" Breakpoint="Breakpoint.Sm" Elevation="0" Class="mb-8 glass-panel rounded-xl">
        <HeaderContent>
            <MudTh><MudText Typo="Typo.subtitle2" Class="font-weight-bold">Name</MudText></MudTh>
            <MudTh><MudText Typo="Typo.subtitle2" Class="font-weight-bold">Gift Notes</MudText></MudTh>
            <MudTh><MudText Typo="Typo.subtitle2" Class="font-weight-bold">Exclusions</MudText></MudTh>
            <MudTh><MudText Typo="Typo.subtitle2" Class="font-weight-bold">Actions</MudText></MudTh>
        </HeaderContent>
        <RowTemplate>
            <MudTd DataLabel="Name">
                <MudText Typo="Typo.body1" Class="font-weight-bold">@context.Name</MudText>
            </MudTd>
            <MudTd DataLabel="Gift Notes">@context.GiftNotes</MudTd>
            <MudTd DataLabel="Exclusions">
                <MudSelect T="Guid" MultiSelection="true" @bind-SelectedValues="context.ExclusionIds" 
                           Label="Select exclusions" AnchorOrigin="Origin.BottomCenter" Variant="Variant.Outlined" Margin="Margin.Dense"
                           ToStringFunc="@(id => Participants.FirstOrDefault(p => p.Id == id)?.Name ?? "Unknown")">
                    @foreach (var p in Participants.Where(p => p.Id != context.Id))
                    {
                        <MudSelectItem T="Guid" Value="@p.Id">@p.Name</MudSelectItem>
                    }
                </MudSelect>
            </MudTd>
            <MudTd DataLabel="Actions">
                <MudIconButton Icon="@Icons.Material.Filled.Delete" Color="Color.Error" OnClick="@(() => RemoveParticipant(context.Id))" />
            </MudTd>
        </RowTemplate>
    </MudTable>

    <div class="glass-panel pa-6 rounded-xl d-flex flex-column gap-4 align-center text-center">
        <MudText Typo="Typo.h6" Class="font-weight-bold">Ready to mix things up?</MudText>
        <MudButton Variant="Variant.Filled" Color="Color.Secondary" Size="Size.Large" OnClick="OnGenerateClicked" FullWidth="true" Class="hover-lift py-3 rounded-lg font-weight-bold" Style="max-width: 400px;">
            Generate Assignments 🎄
        </MudButton>
        <MudButton Variant="Variant.Text" Color="Color.Error" OnClick="OnClearAllParticipants" Class="font-weight-bold">
            Clear All Participants
        </MudButton>
    </div>
}
else
{
    <MudAlert Severity="Severity.Info" Class="rounded-lg mb-6 shadow-sm" ContentAlignment="HorizontalAlignment.Center">
        Add some participants above to get started!
    </MudAlert>
}

@code {
    [Parameter]
    public List<Participant> Participants { get; set; } = new();

    [Parameter]
    public EventCallback<List<Participant>> ParticipantsChanged { get; set; }

    [Parameter]
    public EventCallback OnGenerate { get; set; }

    [Parameter]
    public EventCallback OnClearAll { get; set; }

    private MudForm _form = null!;
    private string _newName = string.Empty;
    private string _newNotes = string.Empty;

    private async Task AddParticipant()
    {
        await _form.ValidateAsync();
        if (_form.IsValid)
        {
            if (Participants.Any(p => p.Name.Equals(_newName, StringComparison.OrdinalIgnoreCase)))
            {
                Snackbar.Add("A participant with this name already exists.", Severity.Warning);
                return;
            }

            var p = new Participant { Name = _newName, GiftNotes = _newNotes };
            Participants.Add(p);
            
            _newName = string.Empty;
            _newNotes = string.Empty;
            await _form.ResetAsync();
            
            await ParticipantsChanged.InvokeAsync(Participants);
        }
    }

    private async Task RemoveParticipant(Guid id)
    {
        Participants.RemoveAll(p => p.Id == id);
        // Remove this participant from everyone's exclusions
        foreach (var p in Participants)
        {
            if (p.ExclusionIds.Contains(id))
            {
                p.ExclusionIds = p.ExclusionIds.Where(e => e != id).ToList();
            }
        }
        await ParticipantsChanged.InvokeAsync(Participants);
    }

    private async Task OnGenerateClicked()
    {
        if (Participants.Count < 2)
        {
            Snackbar.Add("You need at least 2 participants to generate Secret Santa.", Severity.Warning);
            return;
        }

        // Save latest state (especially exclusions) before generating
        await ParticipantsChanged.InvokeAsync(Participants);
        
        await OnGenerate.InvokeAsync();
    }

    private async Task OnClearAllParticipants()
    {
        Participants.Clear();
        await ParticipantsChanged.InvokeAsync(Participants);
        await OnClearAll.InvokeAsync();
    }
}
