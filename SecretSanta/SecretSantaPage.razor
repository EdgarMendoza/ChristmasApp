@page "/secretsanta"
@using ChristmasApp.SecretSanta
@inject SecretSantaService Service
@inject ISnackbar Snackbar

@if (_isLoading)
{
    <MudProgressCircular Color="Color.Primary" Indeterminate="true" />
}
else
{
    if (_assignments.Any() && _showPassPhone)
    {
        <PassPhone Participants="_participants" 
                   Assignments="_assignments" 
                   OnEdit="OnPassPhoneFinished" 
                   OnFinishAndClear="ClearAll" />
    }
    else
    {
        <MudExpansionPanels Class="mb-6">
        <MudExpansionPanel Text="How it works? 🤶" Expanded="false">
            <TitleContent>
                <div class="d-flex align-center">
                    <MudIcon Icon="@Icons.Material.Filled.Help" Class="mr-2" Color="Color.Info" />
                    <MudText Typo="Typo.h6"><b>How it works?</b></MudText>
                </div>
            </TitleContent>
            <ChildContent>
                <MudText Typo="Typo.body2" Class="mb-2">1. <b>Add Participants</b>: Enter everyone's name and optional gift notes/wishlist.</MudText>
                <MudText Typo="Typo.body2" Class="mb-2">2. <b>Set Exclusions</b>: Use the dropdown next to each name to prevent people from drawing each other (e.g., spouses).</MudText>
                <MudText Typo="Typo.body2" Class="mb-2">3. <b>Pass the Phone</b>: Once you generate assignments, pass the phone around. Each person will reveal their secret assignment in private!</MudText>
            </ChildContent>
        </MudExpansionPanel>
    </MudExpansionPanels>

        <ParticipantManager Participants="_participants" 
                            ParticipantsChanged="SaveParticipants" 
                            OnGenerate="GenerateAssignments" 
                            OnClearAll="ClearAll" />
                            
        @if (_assignments.Any())
        {
            <div class="mt-4 text-center">
                <MudButton Variant="Variant.Outlined" Color="Color.Info" OnClick="ResumePassPhone">Resume Passing Phone</MudButton>
                <MudButton Variant="Variant.Text" Color="Color.Error" OnClick="ClearAssignments" Class="ml-2">Clear Assignments</MudButton>
            </div>
        }
    }
}

@code {
    private bool _isLoading = true;
    private bool _showPassPhone = false;
    private List<Participant> _participants = new();
    private List<Assignment> _assignments = new();

    protected override async Task OnInitializedAsync()
    {
        _participants = await Service.GetParticipantsAsync();
        _assignments = await Service.GetAssignmentsAsync();
        
        if (_assignments.Any())
        {
            _showPassPhone = true;
        }

        _isLoading = false;
    }

    private async Task SaveParticipants(List<Participant> updatedList)
    {
        _participants = updatedList;
        await Service.SaveParticipantsAsync(_participants);
    }

    private async Task GenerateAssignments()
    {
        try
        {
            await Service.GenerateAssignmentsAsync();
            _assignments = await Service.GetAssignmentsAsync();
            _showPassPhone = true;
            Snackbar.Add("Assignments generated successfully!", Severity.Success);
        }
        catch (Exception ex)
        {
            Snackbar.Add(ex.Message, Severity.Error);
        }
    }

    private void ResumePassPhone()
    {
        _showPassPhone = true;
    }

    private async Task ClearAssignments()
    {
        await Service.ClearAssignmentsAsync();
        _assignments.Clear();
        _showPassPhone = false;
        Snackbar.Add("Assignments cleared.", Severity.Info);
    }

    private async Task ClearAll()
    {
        await Service.ClearAllAsync();
        _assignments.Clear();
        _showPassPhone = false;
    }

    private async Task OnPassPhoneFinished()
    {
        _showPassPhone = false;
        // Optionally, clear assignments so they can run again
        // await ClearAssignments();
    }
}
