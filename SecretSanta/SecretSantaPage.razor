@page "/secretsanta"
@using ChristmasApp.SecretSanta
@inject SecretSantaService Service
@inject ISnackbar Snackbar

@if (_isLoading)
{
    <MudProgressCircular Color="Color.Primary" Indeterminate="true" />
}
else
{
    if (_assignments.Any() && _showPassPhone)
    {
        <PassPhone Participants="_participants" 
                   Assignments="_assignments" 
                   OnEdit="OnPassPhoneFinished" 
                   OnFinishAndClear="ClearAll" />
    }
    else
    {
        <MudExpansionPanels Class="mb-6" Elevation="0">
            <MudExpansionPanel Class="glass-panel rounded-xl" Expanded="false">
                <TitleContent>
                    <div class="d-flex align-center">
                        <MudIcon Icon="@Icons.Material.Filled.Help" Class="mr-3" Color="Color.Primary" />
                        <MudText Typo="Typo.h6" Class="font-weight-bold">How it works? 🤶</MudText>
                    </div>
                </TitleContent>
                <ChildContent>
                    <div class="pa-2">
                        <MudText Typo="Typo.body1" Class="mb-3"><b style="color: var(--mud-palette-primary);">1. Add Participants:</b> Enter everyone's name and optional gift notes/wishlist.</MudText>
                        <MudText Typo="Typo.body1" Class="mb-3"><b style="color: var(--mud-palette-primary);">2. Set Exclusions:</b> Use the dropdown next to each name to prevent people from drawing each other (e.g., spouses).</MudText>
                        <MudText Typo="Typo.body1" Class="mb-2"><b style="color: var(--mud-palette-primary);">3. Pass the Phone:</b> Once you generate assignments, pass the phone around. Each person will reveal their secret assignment in private!</MudText>
                    </div>
                </ChildContent>
            </MudExpansionPanel>
        </MudExpansionPanels>

        <ParticipantManager Participants="_participants" 
                            ParticipantsChanged="SaveParticipants" 
                            OnGenerate="GenerateAssignments" 
                            OnClearAll="ClearAll" />
                            
        @if (_assignments.Any())
        {
            <div class="mt-8 text-center glass-panel pa-4 rounded-xl">
                <MudText Typo="Typo.h6" Class="mb-4">Assignments already generated!</MudText>
                <MudButton Variant="Variant.Filled" Color="Color.Primary" Size="Size.Large" OnClick="ResumePassPhone" Class="hover-lift px-6 rounded-lg font-weight-bold">
                    Resume Passing Phone
                </MudButton>
                <MudButton Variant="Variant.Text" Color="Color.Error" OnClick="ClearAssignments" Class="ml-4 px-4 font-weight-bold">
                    Clear Assignments
                </MudButton>
            </div>
        }
    }
}

@code {
    private bool _isLoading = true;
    private bool _showPassPhone = false;
    private List<Participant> _participants = new();
    private List<Assignment> _assignments = new();

    protected override async Task OnInitializedAsync()
    {
        _participants = await Service.GetParticipantsAsync();
        _assignments = await Service.GetAssignmentsAsync();
        
        if (_assignments.Any())
        {
            _showPassPhone = true;
        }

        _isLoading = false;
    }

    private async Task SaveParticipants(List<Participant> updatedList)
    {
        _participants = updatedList;
        await Service.SaveParticipantsAsync(_participants);
    }

    private async Task GenerateAssignments()
    {
        try
        {
            await Service.GenerateAssignmentsAsync();
            _assignments = await Service.GetAssignmentsAsync();
            _showPassPhone = true;
            Snackbar.Add("Assignments generated successfully!", Severity.Success);
        }
        catch (Exception ex)
        {
            Snackbar.Add(ex.Message, Severity.Error);
        }
    }

    private void ResumePassPhone()
    {
        _showPassPhone = true;
    }

    private async Task ClearAssignments()
    {
        await Service.ClearAssignmentsAsync();
        _assignments.Clear();
        _showPassPhone = false;
        Snackbar.Add("Assignments cleared.", Severity.Info);
    }

    private async Task ClearAll()
    {
        await Service.ClearAllAsync();
        _assignments.Clear();
        _participants.Clear();
        _showPassPhone = false;
    }

    private async Task OnPassPhoneFinished()
    {
        _showPassPhone = false;
        // Optionally, clear assignments so they can run again
        // await ClearAssignments();
    }
}
