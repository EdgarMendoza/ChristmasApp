@page "/"

<MudContainer MaxWidth="MaxWidth.Small" Class="d-flex flex-column align-center justify-center text-center mt-16" Style="min-height: 70vh;">
    <MudImage Src="/logo.png" Alt="Christmas Helper Logo" Width="500" Class="mb-6 rounded-lg" />
    
    <MudText Typo="Typo.h3" Color="Color.Primary" Class="mb-4" Align="Align.Center"><b>Christmas Helper</b></MudText>
    
    <MudText Typo="Typo.h6" Class="mb-8 font-weight-regular text-muted" Align="Align.Center">
        Your all-in-one companion to help with Christmas-related activities. 
        Organize gift exchanges, manage wishlists, and spread the holiday cheer!
    </MudText>
    
    <MudButton Href="/secretsanta" Variant="Variant.Filled" Color="Color.Secondary" Size="Size.Large" StartIcon="@Icons.Material.Filled.CardGiftcard">
        Start a Secret Santa
    </MudButton>
</MudContainer>